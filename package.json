{
  "name": "crafthost",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "server": "node backend/api.cjs",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "start:prod": "node start-all.js",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:pack": "npm run build && electron-builder --dir",
    "shortcut": "node scripts/create-shortcut.js",
    "setup": "node scripts/setup.js"
  },
  "build": {
    "appId": "com.crafthost.app",
    "productName": "CraftHost",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "backend/**/*",
      "scripts/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      },
      {
        "from": "scripts",
        "to": "scripts"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": ["nsis"],
      "artifactName": "CraftHost Setup ${version}.exe"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "cors": "^2.8.6",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "express": "^5.2.1",
    "lucide-react": "^1.23.0",
    "ngrok": "^5.0.0-beta.2",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "express-rate-limit": "^6.8.0",
    "open": "^9.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
